{
  "name": "webify-backend",
  "version": "1.0.0",
  "description": "Backend API and worker for Webify design tokenizer",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev:server": "tsnd --respawn --transpile-only src/server.ts",
    "dev:worker": "tsnd --respawn --transpile-only src/worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@supabase/supabase-js": "^2.39.0",
    "bullmq": "^5.8.0",
    "colord": "^2.9.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "playwright": "^1.43.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
